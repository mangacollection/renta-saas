generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountStatus {
  active
  suspended
}

enum SubscriptionStatus {
  draft
  active
  cancelled
}

enum InvoiceStatus {
  pending
  paid
  failed
  void
}

enum InvoiceType {
  initial
  monthly
}

enum PaymentMethod {
  transferencia
  link_pago
  efectivo
}

enum LedgerStatus {
  pending_payout
  paid_out
}

enum AccountPaymentStatus {
  received
  approved
  rejected
}

enum TenantPaymentStatus {
  received
  matched
  partial_applied
  applied
  overpayment
  rejected
}

model Account {
  id               String        @id @default(cuid())
  name             String
  status           AccountStatus @default(active)
  maxSubscriptions Int           @default(5)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  billingStartedAt DateTime?
  billingStatus    String        @default("trial")
  plan             String        @default("early_adopter")
  planPrice        Int           @default(6990)
  trialEndsAt      DateTime?
  lastPaymentAt    DateTime?
  nextPaymentDueAt DateTime?
  lastReminderSentAt DateTime?
  lastReminderType   String?

    // 🔥 Billing config (cobranza)
  billingPhone           String?
  billingBankName        String?
  billingAccountType     String?
  billingAccountNumber   String?
  billingAccountHolder   String?
  billingAccountRut      String?
  billingTransferEmail   String?

  accountPayments AccountPayment[]
  paymentSenders  PaymentSender[]
  subscriptions   Subscription[]
  users           User[]
  tenants         Tenant[]
  tenantPayments  TenantPayment[]
  collectionEvents CollectionEvent[]
  
  tenantPaymentSenders TenantPaymentSender[]
}

model AccountPayment {
  id         String               @id @default(cuid())
  accountId  String
  amount     Int
  currency   String               @default("CLP")
  method     String
  channel    String?
  reference  String?
  status     AccountPaymentStatus @default(received)
  createdAt  DateTime             @default(now())
  approvedAt DateTime?
  approvedBy String?
  hadSubscriptionBefore Boolean @default(false)

  account Account @relation(fields: [accountId], references: [id])

  @@index([accountId, createdAt])
}

model User {
  id        String   @id @default(cuid())
  accountId String?
  email     String   @unique
  role      String   @default("owner")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  phone     String?

  account Account? @relation(fields: [accountId], references: [id])
}

model Subscription {
  id                  String             @id @default(cuid())
  accountId           String
  tenantName          String
  tenantRut           String?
  tenantEmail         String?
  billingDay          Int                @default(5)
  status              SubscriptionStatus @default(draft)
  startDate           DateTime           @default(now())
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  tenantPhone         String?

  hasInitialCharges   Boolean            @default(false)
  initialCharges      Json?
  monthlyBillingStart String?
  firstInvoiceType    InvoiceType?

  invoices            Invoice[]
  account             Account            @relation(fields: [accountId], references: [id])
  items               SubscriptionItem[]
  tenant              Tenant?
  tenantPayments      TenantPayment[]

  @@index([accountId])
}

model Tenant {
  id             String   @id @default(cuid())
  accountId      String
  subscriptionId String   @unique
  name           String
  rut            String?
  email          String?
  phone          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  account              Account               @relation(fields: [accountId], references: [id])
  subscription         Subscription          @relation(fields: [subscriptionId], references: [id])
  payments             TenantPayment[]
  tenantPaymentSenders TenantPaymentSender[]

  @@index([accountId])
}

model TenantPaymentSender {
  id        String   @id @default(cuid())
  accountId String
  tenantId  String
  email     String
  bank      String?
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id])
  tenant  Tenant  @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@index([accountId, email])
  @@index([email])
}

model SubscriptionItem {
  id             String   @id @default(cuid())
  subscriptionId String
  type           String
  name           String
  amount         Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
}

model Invoice {
  id             String        @id @default(cuid())
  subscriptionId String
  type           InvoiceType   @default(monthly)
  period         String
  total          Int
  dueDate        DateTime
  status         InvoiceStatus @default(pending)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  subscription   Subscription    @relation(fields: [subscriptionId], references: [id])
  items          InvoiceItem[]
  ledgerEntries  LedgerEntry[]
  payments       Payment[]
  tenantPayments TenantPayment[]
  collectionEvents CollectionEvent[]

  @@unique([subscriptionId, type, period])
  @@index([subscriptionId])
}

enum CollectionChannel {
  whatsapp
}

model CollectionEvent {
  id        String            @id @default(cuid())
  accountId String
  invoiceId String
  channel   CollectionChannel @default(whatsapp)
  message   String
  createdAt DateTime          @default(now())

  account Account @relation(fields: [accountId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([accountId, createdAt])
  @@index([invoiceId, createdAt])
}

model Payment {
  id        String        @id @default(cuid())
  invoiceId String
  method    PaymentMethod
  amount    Int
  paidAt    DateTime      @default(now())
  note      String?
  createdAt DateTime      @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
}

model TenantPayment {
  id             String              @id @default(cuid())
  accountId      String
  tenantId       String
  subscriptionId String
  invoiceId      String?
  amount         Int
  currency       String              @default("CLP")
  channel        String
  reference      String?
  status         TenantPaymentStatus @default(received)
  rawMessage     String?
  paidAt         DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  account      Account      @relation(fields: [accountId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  subscription Subscription @relation(fields: [subscriptionId], references: [id])
  invoice      Invoice?     @relation(fields: [invoiceId], references: [id])

  @@index([accountId, createdAt])
  @@index([tenantId, createdAt])
  @@index([subscriptionId, createdAt])
  @@index([invoiceId])
}

model LedgerEntry {
  id          String       @id @default(cuid())
  accountId   String
  invoiceId   String
  grossAmount Int
  platformFee Int          @default(0)
  netAmount   Int
  status      LedgerStatus @default(pending_payout)
  paidOutAt   DateTime?
  reference   String?
  createdAt   DateTime     @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([accountId, createdAt])
  @@index([invoiceId])
}

model GmailWebhookJob {
  id        String   @id @default(cuid())
  historyId String
  status    String   @default("pending")
  attempts  Int      @default(0)
  lastError String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

model GmailProcessedMessage {
  id        String   @id
  messageId String   @unique
  createdAt DateTime @default(now())
}

model GmailCursor {
  id         String   @id
  historyId  String
  expiration String?
  updatedAt  DateTime @updatedAt
}

model PaymentSender {
  id        String   @id
  email     String
  accountId String
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id])

  @@unique([email, accountId])
}
model InvoiceItem {
  id        String   @id @default(cuid())
  invoiceId String
  label     String
  amount    Int
  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
}
model AutomationRun {
  id              String   @id @default(cuid())
  executedAt      DateTime @default(now())
  totalInvoices   Int
  recommendations Int
}
model PlatformBillingConfig {
  id                   String   @id @default(cuid())
  billingPhone         String?
  billingBankName      String?
  billingAccountType   String?
  billingAccountNumber String?
  billingAccountHolder String?
  billingAccountRut    String?
  billingTransferEmail String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
model EmailLog {
  id        String   @id @default(cuid())
  accountId String?
  email     String
  type      String   // before_3d | before_1d | past_due
  status    String   // sent | failed
  error     String?
  createdAt DateTime @default(now())
}